[general]
# Delivery strategy: "email" (default) or "webdav"
# strategy = email

[sz]
email = your_sz_email@example.com
password = your_sz_password
# Optional:
# Paste your Piano cookies from browser DevTools → Application → Cookies → .sueddeutsche.de
# These are valid for ~20 days. Required if automatic login fails.
# utp_token =
# tac_token =

# --- Email strategy (default) ---
[smtp]
host = smtp.example.com
port = 587
username = your_smtp_user@example.com
password = your_smtp_password
from = your_smtp_user@example.com

[kindle]
to = your_kindle_email@kindle.com

# --- WebDAV strategy ---
# [webdav]
# url = https://your-webdav-server.com/remote.php/dav/files/user/SZ
# username = your_webdav_user
# password = your_webdav_password
